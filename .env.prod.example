DEBUG=False
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING_40_CHARS_MIN
ALLOWED_HOSTS=*
CORS_ALLOW_ALL_ORIGINS=True
USE_INMEMORY_CHANNELS=False
SEED_DEMO=True

# Postgres (docker-compose.prod)
DB_NAME=worktaskme
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# Public URL of your VPS (IP or domain) — no trailing slash
FRONTEND_URL=https://worktaskme.com
CSRF_TRUSTED_ORIGINS=https://worktaskme.com,https://www.worktaskme.com

HOST_PORT=8000

# Email — use smtp backend + Gmail App Password on VPS
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DEFAULT_FROM_EMAIL=yourgmail@gmail.com
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=yourgmail@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password
