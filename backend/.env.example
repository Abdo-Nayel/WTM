DEBUG=True
SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
DB_NAME=worktaskme
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# JWT
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:8080

# Redis (Channels)
REDIS_URL=redis://127.0.0.1:6379/0

# Email (invitations + OTP — console prints codes in the Django terminal)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@worktaskme.com

# Frontend deep-link for invite acceptance / OAuth return
FRONTEND_URL=http://127.0.0.1:8000

# Optional social login (leave empty → DEBUG mock login still works)
# Create OAuth clients in Google Cloud Console / Azure Entra ID
GOOGLE_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_TENANT=common

# Bot protection (pick one). Leave empty in local DEBUG to use checkbox-only.
# CAPTCHA_PROVIDER=recaptcha|turnstile|none
CAPTCHA_PROVIDER=none
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
